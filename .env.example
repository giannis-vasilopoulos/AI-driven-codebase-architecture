# Copy to .env.local and fill in. Never commit real secrets - .env / .env.* are gitignored.
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser bundle - never put a secret there.

# Client-safe: base URL for your GraphQL endpoint
NEXT_PUBLIC_GRAPHQL_URL=

# Client-safe: base URL for REST endpoints
NEXT_PUBLIC_API_URL=

# Server-only secrets (no NEXT_PUBLIC_ prefix)
# SESSION_SECRET=
